# ==============================================================================
# ERG-INVENTORY BACKEND — Plantilla de Variables de Entorno (EJEMPLO)
# ==============================================================================
# Copia este archivo como ".env" en este mismo directorio y completa los valores.
# NUNCA guardes contraseñas ni claves reales en este archivo (.env.example se sube a Git).

# ─── BASE DE DATOS (Supabase PostgreSQL) ───────────────────────────────────────
# URL de conexión JDBC de tu Base de Datos (Supabase Pooler)
DB_URL=jdbc:postgresql://<host-pooler-supabase>:5432/postgres?sslmode=require

# Usuario de la base de datos
DB_USERNAME=postgres.<tu-project-ref>

# Contraseña de la base de datos
DB_PASSWORD=<TU-PASSWORD-DE-BASE-DE-DATOS>

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Clave secreta larga de mínimo 32 caracteres hexadecimales para firmar tokens
JWT_SECRET=<TU-CLAVE-SECRETA-JWT-ALEATORIA>

# Tiempo de expiración de sesión (por defecto: 8 horas)
JWT_EXPIRATION_MS=28800000

# ─── GROQ AI (Asistente POS-AI) ────────────────────────────────────────────────
# API key de Groq (https://console.groq.com/keys)
GROQ_API_KEY=gsk_<tu-api-key-real>

# Modelo principal a utilizar
GROQ_MODEL=llama-3.1-8b-instant

# Modelos de fallback separados por coma
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-20b,openai/gpt-oss-120b

# Máximo de tokens de respuesta
GROQ_MAX_TOKENS=1024
